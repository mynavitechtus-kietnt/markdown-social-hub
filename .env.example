# =============================================
# .env.example — Sao chép thành .env để chạy
# =============================================

# Django
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — Root/Superuser (Docker tạo DB ban đầu)
DB_ROOT_USER=postgres
DB_ROOT_PASSWORD=postgres_root_password

# PostgreSQL — App User (Django kết nối)
DB_NAME=social_hub_db
DB_USER=social_hub_user
DB_PASSWORD=request to author for password
DB_HOST=localhost
DB_PORT=5432
